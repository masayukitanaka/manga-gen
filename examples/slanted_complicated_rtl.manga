// Action scene with skewed borders for dynamic effect

page {
  gutter: 6
  border: 0.5
  direction: rtl

  row {
    col {
      skew_left: -6
      panel pan1{}
    }
    col {
      row {
        panel pan2{
          skew_bottom: 6
          offset_top: -20
        }
      }
      row {
        panel pan3{
          offset_bottom: -20
        }
      }
    }
  }
}
